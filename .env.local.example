# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# NextAuth Configuration
# Open this exact origin for local OAuth; do not switch to localhost mid-flow.
NEXTAUTH_URL=http://local.cassette.tech:3000
NEXTAUTH_SECRET=your-nextauth-secret

# Backend API Configuration
NEXT_PUBLIC_API_URL=https://your-backend-api.com
NEXT_PUBLIC_API_URL_LOCAL=http://localhost:5001

# Spotify API Configuration
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# Apple Music API Configuration
# Get these from https://developer.apple.com/
APPLE_MUSIC_KEY_ID=your-apple-music-key-id
APPLE_MUSIC_TEAM_ID=your-apple-music-team-id
# Private key should be in PEM format with \n for newlines
APPLE_MUSIC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----"

# Feature Flags
NEXT_PUBLIC_ENABLE_LAMBDA_WARMUP=true
# When true, Spotify playlists are created on Cassette's account (no user Spotify login required)
NEXT_PUBLIC_USE_CASSETTE_SPOTIFY_ACCOUNT=false

# Webhook Configuration
REPORT_WEBHOOK_URL=https://your-webhook-url.com

# App Configuration
NEXT_PUBLIC_APP_DOMAIN=http://local.cassette.tech:3000

# GitHub Releases
# Optional token for higher rate limits or private repository access
GITHUB_TOKEN=ghp_your_github_token

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_API_KEY=phc_your_project_key
POSTHOG_HOST=https://us.i.posthog.com
# Optional override host for dashboard provisioning APIs
POSTHOG_APP_HOST=https://app.posthog.com
POSTHOG_PROJECT_ID=218592
POSTHOG_ENVIRONMENT_ID=218592
POSTHOG_PERSONAL_API_KEY=phx_your_personal_api_key
