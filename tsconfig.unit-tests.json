{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": ".unit-test-dist",
    "rootDir": "src",
    "module": "node16",
    "target": "es2020",
    "moduleResolution": "node16",
    "incremental": false,
    "isolatedModules": false,
    "jsx": "react-jsx"
  },
  "include": [
    "src/utils/platform-normalization.ts",
    "src/utils/__tests__/platform-normalization.test.ts",
    "src/utils/content-type-detection.ts",
    "src/utils/deep-link.ts",
    "src/utils/__tests__/deep-link.test.ts",
    "src/utils/music-link-input.ts",
    "src/utils/__tests__/music-link-parsing.test.ts",
    "src/utils/auth-redirect.ts",
    "src/utils/__tests__/auth-redirect.test.ts",
    "src/utils/user-facing-api-error.ts",
    "src/utils/__tests__/user-facing-api-error.test.ts",
    "src/lib/platforms.ts",
    "src/lib/__tests__/platforms.test.ts",
    "src/services/conversion-lifecycle.ts",
    "src/services/__tests__/conversion-lifecycle.test.ts",
    "src/services/__tests__/conversion-contract-fixtures.test.ts",
    "src/app/(sidebar)/internal/_components/explore-snapshot-utils.ts",
    "src/app/(sidebar)/internal/_components/__tests__/explore-snapshot-utils.test.ts",
    "src/lib/analytics/events.ts",
    "src/lib/analytics/sanitize.ts",
    "src/lib/attribution/attribution-links.ts",
    "src/lib/attribution/__tests__/attribution-links.test.ts",
    "src/lib/server/cookie-security.ts",
    "src/lib/server/__tests__/cookie-security.test.ts",
    "src/lib/observability/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
